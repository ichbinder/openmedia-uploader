{
  "servers": [
    {
      "host": "{{USENET_HOST_1}}",
      "port": {{USENET_PORT_1}},
      "user": "{{USENET_USER_1}}",
      "password": "{{USENET_PASS_1}}",
      "ssl": {{USENET_SSL_1}},
      "connections": {{USENET_CONNS_1}},
      "group": "{{USENET_GROUP_1}}"
    },
    {
      "host": "{{USENET_HOST_2}}",
      "port": {{USENET_PORT_2}},
      "user": "{{USENET_USER_2}}",
      "password": "{{USENET_PASS_2}}",
      "ssl": {{USENET_SSL_2}},
      "connections": {{USENET_CONNS_2}},
      "group": "{{USENET_GROUP_2}}"
    }
  ],
  "from": "{{POSTER_NAME}}",
  "_comment_obfuscation": "Nyuu does NOT support an 'obfuscate' config key — it is silently ignored. Real obfuscation uses 'subject' and 'yenc-name' with ${rand(N)} tokens. 'nzb-subject' preserves the original filename in the NZB for NZB holders.",
  "subject": "${rand(20)}",
  "yenc-name": "${rand(15)}",
  "nzb-subject": "[{filenum}/{files}] - \"{filename}\" yEnc ({part}/{parts}) {filesize}",
  "nzb": {
    "output": "{{NZB_OUTPUT_PATH}}",
    "compression": true
  },
  "uploads": {
    "connections": "total",
    "checks": {
      "connections": "all",
      "tries": 3
    }
  }
}
